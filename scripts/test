#!/usr/bin/env bash

# SPDX-FileCopyrightText: 2026 Xquik contributors
#
# SPDX-License-Identifier: Apache-2.0

set -euo pipefail

cd -- "$(dirname -- "$0")/.."

echo "==> Running tests"
case "$(uname -s)" in
  MINGW* | MSYS* | CYGWIN*)
    dotnet test --no-restore --logger "console;verbosity=minimal"
    ;;
  *)
    DOTNET_ROLL_FORWARD=Major dotnet test \
      src/XTwitterScraper.Tests/XTwitterScraper.Tests.csproj \
      --framework net8.0 \
      --no-restore \
      --logger "console;verbosity=minimal"
    ;;
esac
